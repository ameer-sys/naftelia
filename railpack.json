{
  "$schema": "https://schema.railpack.com",
  "providers": ["node", "python"],
  "buildAptPackages": ["libpq-dev"],
  "cmds": {
    "build": "npm install --include=dev && pip install -r backend/requirements.txt && npm run build"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn -w 4 -b 0.0.0.0:$PORT app:app"
  }
}
